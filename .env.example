# =============================================================================
# Kuma Connection (used by viewer dashboard)
# =============================================================================
KUMA_URL=http://192.168.13.14:3001
KUMA_USERNAME=your-kuma-username
KUMA_PASSWORD=your-kuma-password
STATUS_PAGE_SLUG=viewer

# =============================================================================
# Azure AD (used by M365 service health monitor)
# =============================================================================
AZURE_TENANT_ID=28ebe1b7-9cbd-4b94-91b0-1c47ceb89ac7
AZURE_CLIENT_ID=32d5060c-fb49-48b7-a3e7-5dbdeda6f1f8
AZURE_CLIENT_SECRET=your-client-secret

# Kuma push URLs for each tracked M365 service
KUMA_PUSH_EXCHANGE=
KUMA_PUSH_SHAREPOINT=
KUMA_PUSH_TEAMS=
KUMA_PUSH_ONEDRIVE=
KUMA_PUSH_M365SUITE=
KUMA_PUSH_ENTRA=
KUMA_PUSH_POWERAUTOMATE=
KUMA_PUSH_OFFICEWEB=
KUMA_PUSH_FORMS=

# How often to check M365 health (minutes)
M365_CHECK_INTERVAL_MINUTES=10

# =============================================================================
# Vipre Endpoint Security (used by fleet health monitor)
# =============================================================================
VIPRE_KEY_ID=your-vipre-key-id
VIPRE_API_KEY=your-vipre-api-key

# Kuma push URL for the fleet summary monitor
KUMA_PUSH_URL=

# A device is flagged unhealthy if last contact is older than this (days)
STALE_THRESHOLD_DAYS=30

# How often to check Vipre fleet health (minutes)
VIPRE_CHECK_INTERVAL_MINUTES=15

# =============================================================================
# Domain Monitor (expiration, SSL certificate, and online/ping checks)
# =============================================================================

# DOMAIN_LIST — domains that have an active website.
# The monitor will: ping the site, check SSL cert expiration, and check domain expiration.
# Example: nlrlibrary.org has a website, so it goes here.
DOMAIN_LIST=nlrlibrary.org

# DOMAIN_LIST_REG_ONLY — domains that are parked/reserved with no website.
# The monitor will ONLY check domain expiration (no ping, no SSL).
# Example: nlrlibrary.net is a parked domain, so it goes here.
DOMAIN_LIST_REG_ONLY=nlrlibrary.net

# Kuma push URL for each domain above.
# Rule: take the domain name, replace every dot and hyphen with an underscore, make it uppercase.
#
#   nlrlibrary.org  ->  KUMA_PUSH_DOMAIN_NLRLIBRARY_ORG
#   nlrlibrary.net  ->  KUMA_PUSH_DOMAIN_NLRLIBRARY_NET
#
# Paste the push URL from Uptime Kuma after the = sign.
KUMA_PUSH_DOMAIN_NLRLIBRARY_ORG=
KUMA_PUSH_DOMAIN_NLRLIBRARY_NET=

# Warn when domain registration expires within this many days (default: 30)
DOMAIN_EXPIRY_WARN_DAYS=30

# Warn when SSL certificate expires within this many days (default: 14)
SSL_EXPIRY_WARN_DAYS=14

# How often to run domain checks (minutes, default: 60)
DOMAIN_CHECK_INTERVAL_MINUTES=60

# =============================================================================
# General
# =============================================================================
PORT=4000
LOG_LEVEL=info
